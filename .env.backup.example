# Backup workspace
BACKUP_ROOT=/Users/your-user/Projects/tosho-crm/backups
BACKUP_WORKSPACE_ID=
BACKUP_DB_URL=postgresql://postgres:password@host:6543/postgres?sslmode=require
BACKUP_INCLUDE_STORAGE=1

# Supabase Storage S3 compatibility
STORAGE_S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
STORAGE_S3_ACCESS_KEY_ID=your-storage-access-key
STORAGE_S3_SECRET_ACCESS_KEY=your-storage-secret-key
STORAGE_BUCKETS=public-assets,fayna-saas,attachments,avatars

# Dropbox backup upload
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret
DROPBOX_REFRESH_TOKEN=your-dropbox-refresh-token
DROPBOX_BACKUP_ROOT=/Tosho Team Folder/CRM Backups

# Retention
KEEP_ARCHIVES=14
KEEP_STORAGE_ARCHIVES=8
DROPBOX_RETENTION_DATABASE_DAILY=14
DROPBOX_RETENTION_DATABASE_WEEKLY=8
DROPBOX_RETENTION_DATABASE_MONTHLY=6
DROPBOX_RETENTION_STORAGE_DAILY=0
DROPBOX_RETENTION_STORAGE_WEEKLY=8
DROPBOX_RETENTION_STORAGE_MONTHLY=6

# Optional local overrides
PSQL_BIN=/opt/homebrew/opt/libpq/bin/psql
