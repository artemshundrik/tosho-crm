# Frontend-safe values
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_SUPABASE_AVATAR_BUCKET=avatars
VITE_SUPABASE_ITEM_VISUAL_BUCKET=attachments
VITE_WEB_PUSH_PUBLIC_KEY=your-public-vapid-key
VITE_DROPBOX_TEST_SHARED_URL=

# Local-only private values
# Keep these only if you really need local Netlify Functions or scripts.
# Netlify Functions expect server-side names too; VITE_* alone is not enough for `netlify dev`.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4
# Модель транскрибування голосу (диктовка ТЗ/коментарів). Fallback: whisper-1
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
TELEGRAM_SUPPORT_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_SUPPORT_CHAT_ID=your-telegram-chat-id
TOSHO_APP_BASE_URL=http://localhost:8888
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret
DROPBOX_REFRESH_TOKEN=your-dropbox-refresh-token

# Нова Пошта API (довідник адрес). Ключ з кабінету НП → Налаштування → Безпека → Ключі API.
# Секрет: реальне значення тільки в .env.local та Netlify env, НЕ в репо.
NOVA_POSHTA_API_KEY=
